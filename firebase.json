{
  "firestore": {
    "rules": "firestore.rules"
  },
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      "firestore.rules",
      "gcp-creds.json",
      "**/*-service-account.json",
      "**/*.py",
      "tools/**",
      ".venv/**",
      "__pycache__/**",
      ".git/**",
      ".github/**",
      ".vscode/**",
      ".idea/**",
      ".firebaserc",
      ".gitignore",
      "README.md"
    ],
    "rewrites": [
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  }
}
