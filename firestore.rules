rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function ownsExistingDocument() {
      return signedIn() && resource.data.user_id == request.auth.uid;
    }

    function ownsIncomingDocument() {
      return signedIn() && request.resource.data.user_id == request.auth.uid;
    }

    match /users/{userId} {
      allow read, create, update: if signedIn() && request.auth.uid == userId;
      allow delete: if false;
    }

    match /questions/{questionId} {
      allow read: if signedIn();
      allow write: if false;
    }

    match /exams/{examId} {
      allow read, delete: if ownsExistingDocument();
      allow create: if ownsIncomingDocument();
      allow update: if ownsExistingDocument() && ownsIncomingDocument();
    }

    match /exam_answers/{answerId} {
      allow read, delete: if ownsExistingDocument();
      allow create: if ownsIncomingDocument();
      allow update: if ownsExistingDocument() && ownsIncomingDocument();
    }

    match /user_question_stats/{statId} {
      allow read, delete: if ownsExistingDocument();
      allow create: if ownsIncomingDocument();
      allow update: if ownsExistingDocument() && ownsIncomingDocument();
    }
  }
}
